{
	"$schema": "https://github.com/JoaaoVerona/runfile/releases/latest/download/v0.schema.json",
	"globals": {
		"env": {
			"CARGO_TARGET_DIR": "target-{{ RUN.os }}"
		},
		"logging": true,
		"prepare": "@setup"
	},
	"includes": [
		{
			"namespace": "wsl",
			"path": "Runfile-wsl.json"
		}
	],
	"targets": {
		"build": {
			"description": "Build all crates in debug mode",
			"commands": [
				"cargo build {{ ARGS }}",
				{
					"if": "{{ RUN.os == 'windows' }}",
					"then": "@wsl:build"
				},
				"@install"
			]
		},
		"build:release": {
			"description": "Build all crates in release mode",
			"commands": [
				"cargo build --release {{ ARGS }}",
				{
					"if": "{{ RUN.os == 'windows' }}",
					"then": "@wsl:build:release"
				}
			]
		},
		"check": {
			"description": "Non-mutating gate: format check + Clippy (deny warnings; also type/borrow-checks)",
			"commands": [
				"cargo fmt --all -- --check",
				"cargo clippy --all-targets --all-features -- -D warnings",
				{
					"if": "{{ RUN.os == 'windows' }}",
					"then": "@wsl:check"
				}
			]
		},
		"clean": {
			"description": "Remove build artifacts",
			"commands": [
				{
					"for": "dir",
					"in": [
						"",
						"-linux",
						"-mac",
						"-windows"
					],
					"do": "cargo clean --target-dir target{{ VAR.dir }}"
				}
			]
		},
		"install": {
			"description": "Copies the built binary to .local/bin as \"j18nd\"",
			"commands": [
				{
					"if": "{{ RUN.os == 'windows' }}",
					"then": [
						"{{ define(executable, 'j18n.exe') }}",
						"{{ define(installed, 'j18nd.exe') }}"
					],
					"else": [
						"{{ define(executable, 'j18n') }}",
						"{{ define(installed, 'j18nd') }}"
					]
				},
				"cp {{ ENV.CARGO_TARGET_DIR }}/debug/{{ VAR.executable }} ~/.local/bin/{{ VAR.installed }}"
			],
			"detach": true,
			"forceShell": "sh",
			"parallel": true
		},
		"lint": {
			"description": "Completely lints (type-checks, formats, runs Clippy) the project",
			"commands": [
				"cargo fmt --all",
				"cargo clippy --all-targets --all-features -- -D warnings",
				{
					"if": "{{ RUN.os == 'windows' }}",
					"then": "@wsl:lint"
				}
			]
		},
		"precommit": {
			"description": "Format staged Rust files with rustfmt and re-stage them (pre-commit hook body)",
			"commands": [
				"{{ define(rs, capture('git diff --cached --name-only --diff-filter=ACMR -- \"*.rs\" | xargs')) }}",
				{
					"if": "{{ VAR.rs != '' }}",
					"then": [
						"rustfmt {{ VAR.rs }}",
						"git add {{ VAR.rs }}"
					]
				}
			]
		},
		"release": {
			"description": "Bumps the workspace version (major/minor/patch) in Cargo.toml, refreshes Cargo.lock, tags the commit, then pushes everything so CI runs the release",
			"commands": [
				"{{ define(part, one_of(ARGS, 'major', 'minor', 'patch')) }}",
				"{{ define(cargo, read_file('Cargo.toml')) }}",
				"{{ define(cur, regex_capture(VAR.cargo, '(?m)^version = \"([^\"]+)\"', '1')) }}",
				{
					"match": "{{ VAR.part }}",
					"cases": {
						"major": "{{ define(new, concat(add(nth(VAR.cur, '.', '0'), '1'), '.0.0')) }}",
						"minor": "{{ define(new, concat(nth(VAR.cur, '.', '0'), '.', add(nth(VAR.cur, '.', '1'), '1'), '.0')) }}",
						"patch": "{{ define(new, concat(nth(VAR.cur, '.', '0'), '.', nth(VAR.cur, '.', '1'), '.', add(nth(VAR.cur, '.', '2'), '1'))) }}"
					}
				},
				"{{ define(updated, regex_replace(VAR.cargo, '(?m)^version = \"[^\"]+\"', concat('version = \"', VAR.new, '\"'))) }}",
				"{{ write_file('Cargo.toml', VAR.updated) }}",
				"cargo update --workspace",
				"echo 'Bumped: version {{ VAR.cur }} -> {{ VAR.new }}'",
				"git commit Cargo.toml Cargo.lock -m {{ shell_quote(concat('bump to ', VAR.new)) }}",
				"{{ define(tag, concat('v', VAR.new)) }}",
				"echo Tagging {{ VAR.tag }}",
				"git tag {{ shell_quote(VAR.tag) }}",
				"git push",
				"git push --tags"
			],
			"forceShell": "sh"
		},
		"setup": {
			"description": "One-time per clone: activate the committed git hooks",
			"commands": "git config core.hooksPath .githooks"
		},
		"test": {
			"description": "Run all workspace tests",
			"commands": [
				"cargo test {{ ARGS }}",
				{
					"if": "{{ RUN.os == 'windows' }}",
					"then": "@wsl:test"
				}
			]
		}
	}
}
