{
	"$schema": "https://raw.githubusercontent.com/Skiley/rust-binary-publish/v3.0.0/schema/publisher.schema.json",
	"input": {
		"type": "rust-binaries",
		"binary-name": "j18n",
		"crate": "j18n-cli"
	},
	"outputs": [
		{
			"type": "github-release"
		},
		{
			"type": "npm-package",
			"package-name": "@j18n/cli",
			"package-description": "j18n CLI — LLM-powered syncing of translated locale files"
		}
	]
}
